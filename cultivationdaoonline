local function teleportBehindMob(targetMob, distanceBehind)
    distanceBehind = distanceBehind or 4 
    
    local character = player.Character
    if not character then return end
    
    local myRoot = character:FindFirstChild("HumanoidRootPart")
    local mobRoot = targetMob:FindFirstChild("HumanoidRootPart")
    
    if myRoot and mobRoot then
        local rawTargetPos = (mobRoot.CFrame * CFrame.new(0, 0, distanceBehind)).Position
        
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {character, targetMob}
        rayParams.FilterType = Enum.RaycastFilterType.Exclude

        local rayResult = workspace:Raycast(rawTargetPos, Vector3.new(0, -500, 0), rayParams)

        local finalY =  rawTargetPos.Y
        if rayResult then
            finalY = rayResult.Position.Y + 3
        end

        local finalPos = Vector3.new(rawTargetPos.X, finalY, rawTargetPos.Z)
        local lookAtPos = Vector3.new(mobRoot.Position.X, finalPos.Y, mobRoot.Position.Z)

        myRoot.CFrame = CFrame.new(finalPos, lookAtPos)
        
        myRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        myRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end
end

