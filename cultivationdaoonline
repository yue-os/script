local function parseAbbreviatedNumber(text)
    if type(text) ~= "string" then return 0 end
    
    -- 1. Clean the text: convert to lowercase and remove spaces/commas
    text = string.lower(string.gsub(text, "[,%s]", ""))
    
    -- 2. Extract the numeric part and the suffix letters
    local numStr, suffix = string.match(text, "^([%d%.]+)([a-z]*)$")
    if not numStr then return 0 end
    
    local number = tonumber(numStr) or 0
    
    -- 3. Define our multipliers
    local multipliers = {
        k = 1e3,       -- Thousand
        m = 1e6,       -- Million
        b = 1e9,       -- Billion
        t = 1e12,      -- Trillion
        qa = 1e15,     -- Quadrillion
        qi = 1e18,     -- Quintillion
        sx = 1e21,     -- Sextillion
        sp = 1e24,     -- Septillion
        oc = 1e27,     -- Octillion
        no = 1e30,     -- Nonillion
        dc = 1e33      -- Decillion
    }
    
    -- 4. Apply the multiplier if a valid suffix was found
    if suffix and suffix ~= "" and multipliers[suffix] then
        return number * multipliers[suffix]
    end
    
    return number
end

local function parseSpinName(text)
    if type(text) ~= "string" then return "" end
    
    -- Splits the text at the "[" character and takes the first half
    local rawName = string.split(text, "[")[1]
    
    if rawName then
        -- Trims off any extra invisible spaces at the start or end of the word
        return string.match(rawName, "^%s*(.-)%s*$")
    end
    
    return text
end


local function getMyLiveStats()
    local stats = {
        Qi = 0,
        Realm = 1,
        Health = 0,
        Body = 1
    }
    
    if isDelta and PlayerService then
        local success, data = pcall(PlayerService.GetData)
        if success and type(data) == "table" then
            stats.Qi = tonumber(data.Qi) or tonumber(data.qi) or stats.Qi
            stats.Health = tonumber(data.Health) or tonumber(data.HP) or tonumber(data.Hp) or stats.Health
            stats.Realm = tonumber(data.Realm) or tonumber(data.RealmLevel) or stats.Realm
            stats.Body = tonumber(data.Body) or tonumber(data.BodyLevel) or stats.Body
            
            stats.SpiritRoot = data.SpiritRoot or data.Root or data.spiritRoot
            stats.BodyConstitution = data.BodyConstitution or data.Constitution or data.bodyConstitution
            
            if data.Qi or data.qi then
                return stats
            end
        end
    end
    
    if not PlayerGui or not Main then return stats end

    local qiLabel = Main:FindFirstChild("HUD") 
        and Main.HUD:FindFirstChild("Vitals") 
        and Main.HUD.Vitals:FindFirstChild("Qi") 
        and Main.HUD.Vitals.Qi:FindFirstChild("Amount")

    if qiLabel and qiLabel:IsA("TextLabel") then
        stats.Qi = parseAbbreviatedNumber(qiLabel.Text)
    end
    
    local hpLabel = Main:FindFirstChild("HUD") 
        and Main.HUD:FindFirstChild("Vitals") 
        and Main.HUD.Vitals:FindFirstChild("HP") 
        and Main.HUD.Vitals.HP:FindFirstChild("Amount")

    if hpLabel and hpLabel:IsA("TextLabel") then
        stats.Health = parseAbbreviatedNumber(hpLabel.Text)
    end
    
    for _, char in pairs(workspace.Characters:GetChildren()) do
        if char.Name == player.Name then
            local bodyLevel = char:GetAttribute("Body")
            if bodyLevel then stats.Body = tonumber(bodyLevel) end
            
            local realmLevel = char:GetAttribute("Realm")
            if realmLevel then stats.Realm = tonumber(realmLevel) end
            break
        end
    end

    local rootLabel = Main:FindFirstChild("Frames")
        and Main.Frames:FindFirstChild("Shop")
        and Main.Frames.Shop:FindFirstChild("SpiritRoot")
        and Main.Frames.Shop.SpiritRoot:FindFirstChild("Current")

    if rootLabel and rootLabel:IsA("TextLabel") then
        stats.SpiritRoot = parseSpinName(rootLabel.Text)
    end

    local constitutionLabel = Main:FindFirstChild("Frames")
        and Main.Frames:FindFirstChild("Shop")
        and Main.Frames.Shop:FindFirstChild("BodyConstitution")
        and Main.Frames.Shop.BodyConstitution:FindFirstChild("Current")

    if constitutionLabel and constitutionLabel:IsA("TextLabel") then
        stats.BodyConstitution = parseSpinName(constitutionLabel.Text)
    end

    return stats
end

