local function getAnySelectedMobTarget()
    -- Create a quick dictionary for faster checking
    local selectedDict = {}
    for _, name in ipairs(selectedMobsToFarm) do
        selectedDict[name] = true
    end

    -- Scan through the live mobs to find one that matches our selected list
    for _, mobList in pairs(allMobsData) do
        for _, mob in ipairs(mobList) do
            if selectedDict[mob.Name] then
                local hum = mob:FindFirstChild("Humanoid")
                local hrp = mob:FindFirstChild("HumanoidRootPart")
                
                -- Check if it's alive and valid
                if hum and hum.Health > 0 and hrp then
                    return mob
                end
            end
        end
    end
    return nil
end

local function setupInstantPrompts(state)
    task.spawn(function()
        while state do
            -- Look through all instances in the game
            for _, descendant in ipairs(workspace:GetDescendants()) do
                if descendant:IsA("ProximityPrompt") then
                    -- Set the hold time to 0 for instant interaction
                    if descendant.HoldDuration ~= 0 then
                        descendant.HoldDuration = 0
                    end
                end
            end
            -- Wait a short time before checking again for new prompts
            task.wait(1) 
        end
    end)
end

