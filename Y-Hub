local function sendLogToServer(keyUsed, errorMessage)
    pcall(function()
        local HttpService = game:GetService("HttpService")
        local logData = {
            key = keyUsed,
            error = errorMessage,
            player = Players.LocalPlayer.Name,
            userId = Players.LocalPlayer.UserId,
            placeId = game.PlaceId
        }
        local jsonData = HttpService:JSONEncode(logData)
        
        local requestFunc = request or http_request or (http and http.request)
        
        if requestFunc then
            requestFunc({
                Url = logUrl,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = jsonData
            })
        else
            game:HttpPost(logUrl, jsonData, "application/json")
        end
    end)
end

local function verifyAndLoad(keyToVerify)
    local cleanedKey = keyToVerify:gsub("%s+", "")
    if cleanedKey == "" then
        Library:Notify("Please enter a key first!", 3)
        return 
    end
    
    Library:Notify("Verifying key with server...", 2)

    -- Fetch HWID using executor's built-in function, fallback to Roblox ClientId
    local hwid = ""
    if type(gethwid) == "function" then
        hwid = gethwid()
    else
        hwid = game:GetService("RbxAnalyticsService"):GetClientId()
    end
    
    local success, response = pcall(function()
        -- Append both the key and the hwid to the GET request
        return game:HttpGet(verifyUrl .. cleanedKey .. "&hwid=" .. hwid)
    end)
    
    if not success or not response then
        Library:Notify("Server Error!", 3)
        warn("Verification failed to connect.")
        return
    end

    local cleanResponse = response:gsub("%s+", "")

    if cleanResponse == "INVALID_HWID" then
        Library:Notify("HWID Mismatch! Key is locked to another device.", 4)
        warn("Key Error: HWID Mismatch")
        return
    elseif cleanResponse ~= "VALID" then
        Library:Notify("Invalid or Expired Key!", 3)
        
        local errorMsg = not success and tostring(response) or "Invalid Server Response: " .. tostring(response)
        warn("Key Error: " .. errorMsg)
        
        sendLogToServer(cleanedKey, "Key Verification Failed: " .. errorMsg)
        
        if isfile and isfile(keyFileName) and delfile then
            delfile(keyFileName)
        end
        return 
    end
    
    if writefile then
        writefile(keyFileName, cleanedKey)
    end
    
    Library:Notify("Key Validated! Loading main script...", 3)
    task.wait(1)
    Library:Unload() 
    
    local scriptName = getGame()
    if not scriptName then
        local success, gameInfo = pcall(function()
            return MarketplaceService:GetProductInfoAsync(game.PlaceId)
        end)
        sendLogToServer(cleanedKey, "Execution Failed: getGame() returned nil for PlaceId " .. tostring(game.PlaceId) .. " in game " .. tostring(gameInfo.Name))
        return
    end

    local scriptUrl = "https://raw.githubusercontent.com/yue-os/2026robloxscripts/refs/heads/main/" .. scriptName .. ".luau"
    
    local loadSuccess, loadError = pcall(function()
        loadstring(game:HttpGet(scriptUrl))()
    end)
    
    if not loadSuccess then
        sendLogToServer(cleanedKey, "Main Script Execution Crashed: " .. tostring(loadError))
        warn("Script failed to load: " .. tostring(loadError))
    end
end

